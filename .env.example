# Supabase credentials (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Portal URL
SITE_URL=http://127.0.0.1:5173

# Public bank / QR config for portal invoices
VITE_BANK_NAME=Vietcombank
VITE_BANK_CODE=VCB
VITE_BANK_ACCOUNT_NUMBER=1234567890
VITE_BANK_ACCOUNT_NAME=CONG TY SMARTSTAY
VITE_BANK_BRANCH=Chi nhanh Quan 1
VITE_DEMO_MODE=false

# SePay webhook auth (server-side only)
SEPAY_WEBHOOK_API_KEY=your-sepay-webhook-api-key
SEPAY_ALLOW_DEMO=false
